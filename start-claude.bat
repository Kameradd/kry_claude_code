@echo off
title Free Claude Code Launcher
echo Starting Free Claude Code proxy server...
start "FCC_SERVER_WINDOW" /min cmd /c "cd /d d:\deepseek && C:\Users\Kertya\.local\bin\uv.exe run uvicorn server:app --host 127.0.0.1 --port 8082 --timeout-graceful-shutdown 5"
echo Waiting for server to initialize...
timeout /t 3 /nobreak >nul
echo Launching Claude Code...
C:\Users\Kertya\.local\bin\uv.exe --project d:\deepseek run fcc-claude %*
echo Stopping proxy server...
taskkill /fi "windowtitle eq FCC_SERVER_WINDOW" /f >nul 2>&1
echo Done!
